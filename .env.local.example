# =============================================================================
# GOOGLE MAPS — TWO KEYS
# Create both at: https://console.cloud.google.com/apis/credentials
# =============================================================================

# --- BROWSER KEY (public — bundled into the client) -------------------------
# Variable: NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
# Used for:  map tiles/markers, address autocomplete (hero + route search)
# Enable:    Maps JavaScript API, Places API (New)
# Restrict:   HTTP referrers → http://localhost:3000/* and https://your-domain/*
# Do NOT enable on this key: Directions API, Places API (legacy)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_browser_api_key_here

# --- SERVER KEY (private — never use NEXT_PUBLIC_) --------------------------
# Variable: GOOGLE_MAPS_API_KEY
# Used for:  POST /api/directions, POST /api/places/nearby (rate-limited)
# Enable:    Directions API, Places API (legacy — Nearby Search)
# Restrict:   Application = None on Vercel (no fixed outbound IP)
# Do NOT enable on this key: Maps JavaScript API, Places API (New)
GOOGLE_MAPS_API_KEY=your_server_api_key_here

# Nearby Search pages 2–3 (up to 60 results per stop). Off by default to save quota.
# NEARBY_SEARCH_PAGINATION=true

# Map ID for Advanced Markers (Maps → Map Management in Cloud Console)
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=your_map_id_here

# =============================================================================
# RATE LIMITING (optional locally, recommended on Vercel)
# Free database: https://console.upstash.com/
# =============================================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Skip all quota checks locally (unlimited searches).
# DISABLE_RATE_LIMIT=true

# Short quota window for manual testing — prefer: npm run dev:quota-test
# (3 searches / 1 min window, 1 s click cooldown). Or set manually:
# RATE_LIMIT_TEST=true
# NEXT_PUBLIC_RATE_LIMIT_TEST=true

# =============================================================================
# OPTIONAL — not used by the app today
# =============================================================================
# GEMINI_API_KEY=
